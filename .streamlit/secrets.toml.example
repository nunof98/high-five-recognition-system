# Copy this file to secrets.toml and fill in real values.
# Never commit secrets.toml to source control.

ADMIN_PASSWORD = "your-admin-password"

[github]
token     = "github_pat_..."          # Fine-grained PAT: Contents read+write on this repo
repo      = "nunof98/high-five-recognition-system"
file_path = "data/highfive_data.enc"

[encryption]
# Generate a key once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
key = "REPLACE_WITH_GENERATED_KEY="
